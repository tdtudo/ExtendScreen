<Window x:Class="ExtendScreenClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ExtendScreen Client" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e2e">

    <Grid>
        <!-- 连接面板 -->
        <StackPanel x:Name="ConnectPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Width="360">
            <TextBlock Text="ExtendScreen Client" FontSize="24" FontWeight="Bold"
                       Foreground="#cdd6f4" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <TextBlock Text="服务端 IP 地址" Foreground="#a6adc8" Margin="0,0,0,5"/>
            <TextBox x:Name="IpBox" Text="192.168." FontSize="16" Height="36"
                     Background="#313244" Foreground="#cdd6f4" BorderBrush="#45475a"
                     Padding="8,0,0,0" VerticalContentAlignment="Center"/>

            <TextBlock Text="视频端口" Foreground="#a6adc8" Margin="0,15,0,5"/>
            <TextBox x:Name="VideoPortBox" Text="12348" FontSize="16" Height="36"
                     Background="#313244" Foreground="#cdd6f4" BorderBrush="#45475a"
                     Padding="8,0,0,0" VerticalContentAlignment="Center"/>

            <TextBlock Text="输入端口" Foreground="#a6adc8" Margin="0,15,0,5"/>
            <TextBox x:Name="InputPortBox" Text="12347" FontSize="16" Height="36"
                     Background="#313244" Foreground="#cdd6f4" BorderBrush="#45475a"
                     Padding="8,0,0,0" VerticalContentAlignment="Center"/>

            <Button x:Name="ConnectBtn" Content="连接" Height="42" FontSize="16" FontWeight="Bold"
                    Background="#89b4fa" Foreground="#1e1e2e" BorderThickness="0"
                    Margin="0,25,0,0" Click="ConnectBtn_Click"/>
        </StackPanel>

        <!-- 视频显示区域 -->
        <Grid x:Name="VideoPanel" Visibility="Collapsed">
            <Image x:Name="VideoImage" Stretch="Fill"
                   MouseDown="VideoImage_MouseDown"
                   MouseUp="VideoImage_MouseUp"
                   MouseMove="VideoImage_MouseMove"
                   MouseWheel="VideoImage_MouseWheel"/>

            <!-- 顶部状态栏 -->
            <Border Background="#80000000" Height="36" VerticalAlignment="Top"
                    CornerRadius="0,0,4,4" Padding="12,0">
                <Grid>
                    <TextBlock x:Name="StatusText" Text="已连接" Foreground="#a6e3a1"
                           VerticalAlignment="Center" FontSize="13"/>
                    <Button x:Name="DisconnectBtn" Content="断开" Height="26" Width="70"
                        Background="#f38ba8" Foreground="#1e1e2e" BorderThickness="0"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Click="DisconnectBtn_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
