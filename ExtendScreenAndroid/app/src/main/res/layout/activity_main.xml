<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- JPEG 画面渲染 -->
    <ImageView
        android:id="@+id/video_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:visibility="gone" />

    <!-- 断开按钮（悬浮在视频画面上方） -->
    <Button
        android:id="@+id/btn_disconnect"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:backgroundTint="#CC3333"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:text="断开"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- 主页：选择连接模式 -->
    <LinearLayout
        android:id="@+id/home_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ExtendScreen"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="选择连接方式"
            android:textColor="#888888"
            android:textSize="14sp"
            android:layout_marginBottom="36dp" />

        <Button
            android:id="@+id/btn_wifi_mode"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:backgroundTint="#1565C0"
            android:text="Wi-Fi 连接"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btn_usb_mode"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:backgroundTint="#2E7D32"
            android:text="USB 连接"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- Wi-Fi 连接页面 -->
    <LinearLayout
        android:id="@+id/wifi_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wi-Fi 连接"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <ProgressBar
            android:id="@+id/connecting_spinner"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:indeterminateTint="#4FC3F7" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="正在搜索电脑..."
            android:textColor="#AAAAAA"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="或手动输入电脑IP"
            android:textColor="#666666"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/et_ip"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="#1A1A2E"
                android:hint="192.168.x.x"
                android:inputType="text"
                android:maxLines="1"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btn_connect"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginLeft="10dp"
                android:backgroundTint="#1565C0"
                android:paddingLeft="18dp"
                android:paddingRight="18dp"
                android:text="连接"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

        </LinearLayout>

        <Button
            android:id="@+id/btn_wifi_back"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="20dp"
            android:backgroundTint="#444444"
            android:text="返回"
            android:textColor="#CCCCCC"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- USB 连接页面 -->
    <LinearLayout
        android:id="@+id/usb_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="USB 连接"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1. 用数据线连接平板和电脑\n2. 开启 USB 调试\n3. 在电脑端点击「USB 连接」\n4. 点击下方按钮连接"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="24dp" />

        <ProgressBar
            android:id="@+id/usb_spinner"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:indeterminateTint="#4CAF50"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_usb_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text=""
            android:textColor="#AAAAAA"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_usb_connect"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="20dp"
            android:backgroundTint="#2E7D32"
            android:text="连接"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_usb_back"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="#444444"
            android:text="返回"
            android:textColor="#CCCCCC"
            android:textSize="13sp" />

    </LinearLayout>

</FrameLayout>
